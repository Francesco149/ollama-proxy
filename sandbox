#!/usr/bin/env bash
# sandbox — run the ollama-proxy shell-server inside a Docker container
# mounted on the current project directory.
#
# Usage:
#   sandbox                   # start (blocking, Ctrl-C to stop)
#   sandbox build             # rebuild the Docker image
#   sandbox stop              # stop a running sandbox container
#
# Environment variables:
#   PROXY_URL    proxy to register with (default: http://host.docker.internal:11434)
#   SHELL_PORT   host port to expose (default: 8000)

set -euo pipefail

IMAGE="ollama-proxy-sandbox"
CONTAINER="ollama-proxy-sandbox-run"
PROXY_URL="${PROXY_URL:-http://host.docker.internal:11434}"
SHELL_PORT="${SHELL_PORT:-8000}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(pwd)"

build() {
    echo "[sandbox] Building image ${IMAGE}..."
    docker build -t "${IMAGE}" "${SCRIPT_DIR}"
    echo "[sandbox] Build complete."
}

stop_existing() {
    if docker ps -q --filter "name=${CONTAINER}" | grep -q .; then
        echo "[sandbox] Stopping existing container..."
        docker rm -f "${CONTAINER}" >/dev/null
    fi
}

start() {
    stop_existing

    if ! docker image inspect "${IMAGE}" >/dev/null 2>&1; then
        build
    fi

    echo "[sandbox] Starting sandbox"
    echo "  Project : ${PROJECT_DIR}"
    echo "  Proxy   : ${PROXY_URL}"
    echo "  Port    : ${SHELL_PORT}"

    # Mount SCRIPT_DIR read-only when it differs from PROJECT_DIR so
    # shell_server.py is always reachable at its real path.
    EXTRA_MOUNT=""
    if [ "${SCRIPT_DIR}" != "${PROJECT_DIR}" ]; then
        EXTRA_MOUNT="-v ${SCRIPT_DIR}:${SCRIPT_DIR}:ro"
    fi

    # Git identity — mount host gitconfig and credentials read-only
    # into /root and /home/ubuntu (covers both root and named-user cases).
    GIT_MOUNTS=""
    [ -f "${HOME}/.gitconfig" ] && \
        GIT_MOUNTS="${GIT_MOUNTS} -v ${HOME}/.gitconfig:/home/ubuntu/.gitconfig:ro"
    [ -f "${HOME}/.git-credentials" ] && \
        GIT_MOUNTS="${GIT_MOUNTS} -v ${HOME}/.git-credentials:/home/ubuntu/.git-credentials:ro"

    mkdir -p /tmp/scratch/
    docker run --rm \
        --name "${CONTAINER}" \
        --user "$(id -u):$(id -g)" \
        --add-host host.docker.internal:host-gateway \
        -e PROXY_URL="${PROXY_URL}" \
        -v "${PROJECT_DIR}:${PROJECT_DIR}" \
        -v /tmp/scratch/:/tmp/scratch/ \
        ${EXTRA_MOUNT} \
        ${GIT_MOUNTS} \
        -p "${SHELL_PORT}:8000" \
        -w "${PROJECT_DIR}" \
        "${IMAGE}" \
        python3 "${SCRIPT_DIR}/shell_server.py"
}

case "${1:-start}" in
    build)  build ;;
    stop)   stop_existing; echo "[sandbox] Stopped." ;;
    start)  start ;;
    *)      echo "Usage: sandbox [start|stop|build]"; exit 1 ;;
esac
